DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/consensus
ASYNC_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/consensus
SEARXNG_URL="http://localhost:8081"

# .env

LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Keep local machine safer
OLLAMA_KEEP_ALIVE=0
OLLAMA_SAFE_NUM_CTX=2048
OLLAMA_SAFE_NUM_PREDICT=800
OLLAMA_SAFE_TIMEOUT_S=240

# Draft generation
DRAFT_AI_MAX_TOKENS=650
DRAFT_AI_TIMEOUT_S=240

# Amendment generation
AMEND_AI_MAX_TOKENS=800
AMEND_AI_TIMEOUT_S=240